APP_NAME="CORPIUS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://corpius.net


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# APP_MAINTENANCE_STORE=database
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=icorp_pro
DB_USERNAME=icorp_user
DB_PASSWORD=icorp_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# Force HTTPS
FORCE_HTTPS=true
APP_FORCE_HTTPS=true
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=file

# CACHE_PREFIX=
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mail.revold.us
MAIL_PORT=587
MAIL_USERNAME=support@corpius.net
MAIL_PASSWORD="++79Algoritm73@#"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="support@corpius.net"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
VITE_APP_NAME="${APP_NAME}"

# Stripe Configuration
STRIPE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_CRYPTO_ENABLED=false

# Supported Crypto Payment Methods (comma-separated)
# Options: bitcoin, ethereum, usdc, usdt, litecoin, dogecoin
STRIPE_CRYPTO_CURRENCIES=bitcoin,ethereum,usdc

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_LIVE_CLIENT_ID=YOUR_PAYPAL_LIVE_CLIENT_ID
PAYPAL_LIVE_CLIENT_SECRET=YOUR_PAYPAL_LIVE_CLIENT_SECRET
PAYPAL_SANDBOX_CLIENT_ID=YOUR_PAYPAL_SANDBOX_CLIENT_ID
PAYPAL_SANDBOX_CLIENT_SECRET=YOUR_PAYPAL_SANDBOX_CLIENT_SECRET
PAYPAL_CURRENCY=USD

# File Upload Settings
MAX_FILE_SIZE=10240
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# KYC Settings
KYC_DOCUMENT_RETENTION_DAYS=365
KYC_ENCRYPTION_KEY=YOUR_32_CHAR_ENCRYPTION_KEY

# Application Settings
DEFAULT_CURRENCY=USD
SUPPORT_EMAIL=support@corpius.net
COMPANY_ADDRESS="200 Central Park S, New York, NY 10019"
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# AI Assistant (self-host ollama with litellm) Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=ollama/kimi-k2.5:cloud
OPENAI_BASE_URL=https://litellm.revold.us

# Chatwoot Configuration
CHATWOOT_URL=http://chatwoot:3000
CHATWOOT_API_TOKEN=YOUR_CHATWOOT_API_TOKEN
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_WEBSITE_TOKEN=YOUR_CHATWOOT_WEBSITE_TOKEN
CHATWOOT_IDENTITY_SECRET=

# Google Analytics 4 (GA4)
GA4_PROPERTY_ID=506612267
GA4_CREDENTIALS_PATH=/var/www/storage/app/google-credentials.json

# Google Search Console (GSC)
GSC_SITE_URL=https://corpius.net
GSC_CREDENTIALS_PATH=/var/www/storage/app/google-credentials.json


